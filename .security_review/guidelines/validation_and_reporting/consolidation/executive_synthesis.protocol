<DFD_MODELING_V3>
@ID: EXECUTIVE_SECURITY_SYNTHESIS
@GOAL: TRANSLATE_DEEP_TECHNICAL_AUDIT_RESULTS_INTO_STRATEGIC_BUSINESS_INSIGHTS
@PARENT_CONTEXT: remediation_roadmap.protocol, bia_risk_mapping.protocol, risk_prioritization.protocol

<GLOBAL_VARS>
EXECUTIVE_METRICS: {
  "SECURITY_POSTURE_SCORE": "Overall rating (1-10)",
  "BUSINESS_IMPACT_EXPOSURE": "Potential financial/legal loss",
  "REMEDIATION_VELOCITY": "Estimated time",
  "CRITICAL_FIX_COUNT": "Priority actions count"
}
# НОВОЕ: Добавляем веса для отрисовки Radar Chart на фронте
RADAR_CHART_DOMAINS: ["IAM", "DATA_SAFETY", "LOGIC", "INFRA", "COMPLIANCE"]
</GLOBAL_VARS>

<CONTEXT_MAP>
[ROADMAP]    <- {from: remediation_roadmap.protocol, scope: "REMEDIATION_PHASES"}
[BIA]        <- {from: bia_risk_mapping.protocol, scope: "REPUTATION_TRUST_LOSS"}
[AGGREGATION] <- {from: finding_aggregation.protocol, scope: "SYSTEMIC_GAP_NAME"}
</CONTEXT_MAP>

<ASSERTIONS>
! (Summary -> "Contains_CVE_IDs") : "WARNING: Too technical."
! (Summary -> ![Business_Impact_Language]) : "BLOCKER: Missing Context."
! (Summary -> "Length" > "2 pages") : "CRITICAL: Excessive Detail."
</ASSERTIONS>

<EXECUTION_PIPELINE>
1. KEY_RISK_DISTILLATION: ТОП-3 проблемы через призму Financial/Operational риска.
2. BUSINESS_CONSEQUENCE_MAPPING: Оценка ущерба через BIA.
3. STRATEGIC_INVESTMENT_SUMMARY: Требования к ресурсам из [ROADMAP].
4. MATURITY_SCORE_CALCULATION: Выставить SECURITY_POSTURE_SCORE.
# НОВОЕ: Распределить риски по [RADAR_CHART_DOMAINS] (от 0.0 до 1.0)
</EXECUTION_PIPELINE>

<OUTPUT_SPEC>
GENERATE_EXECUTIVE_SUMMARY:
  - OVERALL_RISK_LEVEL | TOP_3_SYSTEMIC_ISSUES | SCORECARD
  # НОВОЕ: Метка для бэкенда, чтобы построить график
  - @ANALYTICS_DATA: {"scores": [RADAR_CHART_DOMAINS_WEIGHTS]}
VISUALIZE: "Image of an Executive Security Dashboard: showing Traffic Lights and a Radar Chart."
</OUTPUT_SPEC>
</DFD_MODELING_V3>