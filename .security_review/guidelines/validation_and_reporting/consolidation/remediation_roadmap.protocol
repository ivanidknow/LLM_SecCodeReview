<DFD_MODELING_V3>
@ID: REMEDIATION_ROADMAP_STRATEGY
@GOAL: CONSTRUCT_A_PHASED_PLAN_WITH_ROOT_CAUSE_ELIMINATION
@PARENT_CONTEXT: finding_aggregation.protocol, cost_of_remediation.protocol, root_cause_analysis.protocol

<GLOBAL_VARS>
REMEDIATION_PHASES: {
  "PHASE_1_IMMEDIATE": "Hotfixes for CRITICAL/HIGH findings (Quick Wins)",
  "PHASE_2_TACTICAL": "Addressing systemic gaps (Middleware/Shared Libs)",
  "PHASE_3_STRATEGIC": "Architectural shifts (Vault, mTLS, RBAC migration)"
}
# НОВОЕ: Связь с бизнес-целями
KPI_ALIGNMENT: ["REDUCE_PII_EXPOSURE", "FIX_AUTH_ARCHITECTURE", "SUPPLY_CHAIN_HARDENING"]
</GLOBAL_VARS>

<ASSERTIONS>
! (Roadmap -> ![Phase_Allocation]) : "BLOCKER: Flat Remediation List."
! (Step -> "Action: Fix" && ![Verification_Method]) : "CRITICAL: Missing Validation Method."
</ASSERTIONS>

<EXECUTION_PIPELINE>
1. CLUSTER_ALLOCATION:
   - Сгруппировать находки из [AGGREGATION] по фазам [REMEDIATION_PHASES].
2. ROOT_CAUSE_MAPPING:
   - Для каждой фазы указать фундаментальную причину (например, "Отсутствие централизованной Auth-библиотеки").
3. RESOURCE_ESTIMATION:
   - Оценить время исправления (S/M/L/XL).
4. VERIFICATION_PLAN:
   - Указать, как подтвердить фикс (например, "Re-run Sub-Phase 2").
</EXECUTION_PIPELINE>

<OUTPUT_SPEC>
GENERATE_REMEDIATION_PLAN:
  - PHASE | ACTION_ITEM | ROOT_CAUSE | LINKED_FINDINGS | KPI_IMPACT | VERIFICATION | DEADLINE
  # НОВОЕ: Итоговое резюме для руководства
  - STRATEGIC_SUMMARY: "Brief explanation of how these fixes improve Security Posture Score."
VISUALIZE: "Image of a Security Remediation Roadmap: illustrating the progression from urgent hotfixes to strategic changes."
</OUTPUT_SPEC>
</DFD_MODELING_V3>